{
  "expo": {
    "name": "MeatManager Mobile",
    "slug": "meatmanager",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#f7f4ee"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.meatmanager.mobile",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "MeatManager necesita tu ubicacion para informar el seguimiento de entregas en tiempo real.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.meatmanager.mobile",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      "expo-location"
    ],
    "extra": {
      "eas": {
        "projectId": "217d824d-37fa-42e3-b3cc-acac32e5e3fb"
      }
    },
    "owner": "def-software-organization"
  }
}
