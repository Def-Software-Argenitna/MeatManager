# ─── MySQL ────────────────────────────────────────────
DB_HOST=host.docker.internal
DB_PORT=3306
DB_USER=root
DB_PASS=tu_password_aqui
MEATMANAGER_DB_NAME=meatmanager
OPERATIONAL_DB_NAME=meatmanager
DEFAULT_OPERATIONAL_TENANT_ID=1

# ─── Firebase Admin SDK ───────────────────────────────
# Descargá el JSON de Firebase Console > Configuración > Cuentas de servicio
FIREBASE_SERVICE_ACCOUNT=./firebase-service-account.json

# ─── API ──────────────────────────────────────────────
PORT=3001
MEATMANAGER_DB_NAME=meatmanager
OPERATIONAL_DB_NAME=meatmanager
CLIENTS_DB_NAME=GestionClientes
CLIENTS_DB_HOST=host.docker.internal
CLIENTS_DB_PORT=3306
CLIENTS_DB_USER=root
CLIENTS_DB_PASS=tu_password_clientes
CLIENTS_TABLE=clients
CLIENT_USERS_TABLE=client_users
CLIENT_LICENSES_TABLE=client_licenses
CLIENT_USER_PERMISSIONS_TABLE=client_user_permissions
LICENSES_TABLE=licenses
CORS_ORIGIN=http://localhost:5176,https://tu-dominio.com

# ─── Redis Tracking ──────────────────────────────────
REDIS_HOST=host.docker.internal
REDIS_PORT=6379
REDIS_USER=default
REDIS_PASS=tu_password_redis
REDIS_TLS=false
REDIS_TLS_REJECT_UNAUTHORIZED=false
REDIS_DB=0
REDIS_TRACKING_TTL_SECONDS=90

# ─── SMTP / Autorizaciones de caja ──────────────────
SMTP_HOST=smtp.tu-servidor.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu_usuario_smtp
SMTP_PASS=tu_password_smtp
SMTP_FROM="MeatManager <no-reply@tu-dominio.com>"
CASH_WITHDRAWAL_CODE_TTL_MINUTES=10
